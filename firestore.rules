rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Institutions: read allowed; only admin/service account can create/update counters
    match /institutions/{instId} {
      allow read: if true;
      allow create: if request.auth.token.admin == true || request.auth.token.service == true;
      allow update: if request.auth.token.admin == true || request.auth.token.service == true;
      allow delete: if false;
    }

    // Submissions: authenticated users may create their own submissions
    // but cannot set or modify server-controlled fields like firstTenAwarded or status.
    match /submissions/{subId} {
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.keys().hasAll(['ownerUid','institutionId','filename','storagePath','createdAt'])
        && request.resource.data.firstTenAwarded == null
        && request.resource.data.status == 'pending';

      // Only admins/service may modify submission status/award fields
      allow update: if request.auth.token.admin == true || request.auth.token.service == true;
      allow delete: if request.auth.token.admin == true;
    }

    // Users: users may read their own profile, but only admins/service may modify total_points
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth.token.admin == true || request.auth.uid == uid;
      allow delete: if request.auth.token.admin == true;
    }

    // Fallback: deny everything else by default
    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
